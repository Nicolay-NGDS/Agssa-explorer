      "endpoints": [
        { "method": "POST", "path": "/regulacion/secureCommand/validarriesgosmodulos", "description": "Validar riesgos" }
      ],
      "request": { "modulo": "%", "ciudad": "%", "tipoRiesgo": "01", "riesgo": "CODIGO+DOCUMENTO" },
      "response": { "esRiesgo": "boolean", "tipoValidacion": "string", "mensajeValidacion": "string" }
    },
    {
      "id": "hubspot",
