    {
      "id": "validacion-identidad",
      "name": "Flujo de Validacion de Identidad",
      "description": "Validacion biometrica del arrendatario usando TruValidate",
      "type": "flow",
      "dataFlowSummary": "Los intentos de validacion se registran en BD RADICACIONES. Una vez exitosa la validacion, se sincroniza el resultado con BD AGSSA mediante WCF para continuar el analisis de riesgo.",
      "involvedDatabases": [
        { "id": "radicaciones", "role": "temporal" },
        { "id": "agssa", "role": "permanente" }
      ],
      "steps": [
        { "order": 1, "system": "radicacion", "action": "Recibe link por SMS/Email", "detail": "Link con token unico de validacion" },
        { "order": 2, "system": "radicacion", "action": "Verifica tipo documento", "detail": "CC/CE van a biometria, otros a formulario", "controller": "ValidacionIdentidadController", "database": "radicaciones", "entity": "TRadicacione", "dbOperation": "read" },
        { "order": 3, "system": "truvalidate", "action": "Consulta orquestador", "detail": "API determina flujo: OTP o Biometria", "integration": "truvalidate" },
        { "order": 4, "system": "truvalidate", "action": "Flujo OTP (si aplica)", "detail": "Envia SMS con codigo 6 digitos", "endpoint": "/queues/OTP_PhoneSelection" },
        { "order": 5, "system": "radicacion", "action": "Usuario ingresa codigo OTP", "detail": "Valida codigo contra API", "controller": "ValidacionIdentidadController.ValidarOTP", "database": "radicaciones", "entity": "TValidacionesIdentidad", "dbOperation": "write" },
        { "order": 6, "system": "radicacion", "action": "Captura documento", "detail": "Foto frente y reverso de cedula", "controller": "ValidacionIdentidadController.Documento" },
        { "order": 7, "system": "truvalidate", "action": "Valida documento (OCR)", "detail": "Extrae datos y valida autenticidad", "endpoint": "/queues/TSO_ServiceInput" },
        { "order": 8, "system": "radicacion", "action": "Captura selfie", "detail": "Foto del rostro del usuario", "controller": "ValidacionIdentidadController.Selfie" },
        { "order": 9, "system": "truvalidate", "action": "Valida reconocimiento facial", "detail": "Compara selfie con foto del documento", "integration": "truvalidate" },
        { "order": 10, "system": "radicacion", "action": "Guarda validacion", "detail": "Registra resultado en BD y sincroniza con AGSSA", "service": "ValidarIdentidadServices", "database": "radicaciones", "entity": "TValidacionesIdentidad", "dbOperation": "write" },
        { "order": 11, "system": "radicacion", "action": "Sincroniza con AGSSA", "detail": "WCF GuardarValidacionIdentidad - PUNTO DE SINCRONIZACION", "wcf": "wcf-external-solution", "database": "agssa", "entity": "CSolicitudes", "dbOperation": "sync" },
        { "order": 12, "system": "agssasura", "action": "Ejecuta Motor Decision", "detail": "Continua analisis de riesgo", "wcf": "wcf-motor-decision", "database": "agssa", "entity": "CAnalisis", "dbOperation": "write" }
      ]
    },
    {
      "id": "analisis-riesgo",
      "name": "Flujo de Analisis de Riesgo",
      "description": "Evaluacion de riesgo de la solicitud con motor de decision",
      "type": "flow",
      "dataFlowSummary": "Todo el proceso de analisis ocurre en BD AGSSA. La solicitud ya fue creada previamente y aqui se evalua el riesgo consultando centrales externas (SURA) y aplicando reglas de negocio.",
      "involvedDatabases": [
        { "id": "agssa", "role": "permanente" }
