  "flows": [
    {
      "id": "radicacion",
      "name": "Flujo de Radicacion",
      "description": "Proceso completo desde que la inmobiliaria genera el link hasta que se crea la solicitud en AGSSA",
      "type": "flow",
      "dataFlowSummary": "Los datos se guardan temporalmente en BD RADICACIONES mientras el arrendatario completa el formulario y pago. Una vez confirmado el pago, se crea la solicitud definitiva en BD AGSSA mediante el servicio WCF ExternalSolutionService.",
      "involvedDatabases": [
        { "id": "radicaciones", "role": "temporal" },
        { "id": "agssa", "role": "permanente" }
      ],
      "steps": [
        { "order": 1, "system": "landing", "action": "Genera link de radicacion", "detail": "Inmobiliaria accede a LinksRadicacion.aspx y copia el link", "sp": "P_GenerarLinksInmobiliarias", "database": "agssa", "entity": "CInmobiliaria", "dbOperation": "read" },
        { "order": 2, "system": "radicacion", "action": "Arrendatario accede al link", "detail": "LinksPersonalizadosController valida el token", "controller": "LinksPersonalizadosController" },
        { "order": 3, "system": "radicacion", "action": "Completa formulario", "detail": "Datos personales, inmueble, propietario", "controller": "HomeController", "database": "radicaciones", "entity": "TRadicacione, TInformacionBasica, TInmueble", "dbOperation": "write" },
        { "order": 4, "system": "radicacion", "action": "Valida reCAPTCHA", "detail": "Google reCAPTCHA v3", "service": "RecaptchaServices" },
        { "order": 5, "system": "radicacion", "action": "Ingresa datos facturacion", "detail": "Nombre, documento, email para factura", "controller": "FacturacionPagoController", "database": "radicaciones", "entity": "TFacturacion", "dbOperation": "write" },
        { "order": 6, "system": "radicacion", "action": "Valida convenio (opcional)", "detail": "Si tiene codigo de convenio, aplica descuento", "service": "ConvenioServices", "database": "agssa", "entity": "CConvenio", "dbOperation": "read" },
        { "order": 7, "system": "wompi", "action": "Realiza pago", "detail": "Modal de Wompi procesa tarjeta", "integration": "wompi" },
        { "order": 8, "system": "radicacion", "action": "Webhook recibe confirmacion", "detail": "Valida firma SHA256, verifica APPROVED", "controller": "ApiWompiController", "database": "radicaciones", "entity": "TPago", "dbOperation": "write" },
        { "order": 9, "system": "radicacion", "action": "Crea solicitud en AGSSA", "detail": "Llama servicio WCF ExternalSolutionService - PUNTO DE SINCRONIZACION", "service": "ExternalServices", "wcf": "wcf-external-solution", "database": "agssa", "entity": "CSolicitudes, CArrendatarioPN, CInmueble", "dbOperation": "sync" },
        { "order": 10, "system": "agssasura", "action": "Ejecuta Motor de Decision", "detail": "Analisis automatico de riesgo", "wcf": "wcf-motor-decision", "database": "agssa", "entity": "CAnalisis", "dbOperation": "write" },
        { "order": 11, "system": "radicacion", "action": "Envia SMS confirmacion", "detail": "Notifica al arrendatario", "integration": "masivapp" },
        { "order": 12, "system": "radicacion", "action": "Muestra pagina final", "detail": "Solicitud registrada, pendiente validacion", "controller": "FinalTransaccionController", "database": "radicaciones", "entity": "TRadicacione", "dbOperation": "write" }
      ]
