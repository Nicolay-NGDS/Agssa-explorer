      "steps": [
        { "order": 1, "system": "agssasura", "action": "Motor Decision ejecuta automatico", "detail": "Se activa despues de radicacion", "sp": "P_CrearAnalisisSolicitud", "database": "agssa", "entity": "CAnalisis", "dbOperation": "write" },
        { "order": 2, "system": "agssasura", "action": "Obtiene datos para analisis", "detail": "Informacion de todas las partes", "sp": "P_ListarConsultaMD", "database": "agssa", "entity": "CSolicitudes, CArrendatarioPN, CCodeudor", "dbOperation": "read" },
        { "order": 3, "system": "sura", "action": "Consulta centrales de riesgo", "detail": "Valida riesgos en SURA", "integration": "sura", "endpoint": "/validarriesgosmodulos" },
        { "order": 4, "system": "agssasura", "action": "Asigna analista", "detail": "Si requiere revision manual", "sp": "P_AsignarAutoAnalista", "database": "agssa", "entity": "CAnalisis", "dbOperation": "write" },
        { "order": 5, "system": "agssasura", "action": "Analista revisa", "detail": "Accede a Analisis_10.aspx", "page": "Analisis_10.aspx", "database": "agssa", "entity": "CAnalisis", "dbOperation": "read" },
        { "order": 6, "system": "agssasura", "action": "Ejecuta tabla de verdad", "detail": "Combina resultados de partes", "method": "MNegocio.TablaVerdadAnalisis", "database": "agssa", "entity": "CAnalisis", "dbOperation": "read" },
        { "order": 7, "system": "agssasura", "action": "Emite concepto", "detail": "APROBADO, RECHAZADO o APLAZADO", "sp": "P_EmitirResultadoAnalisis", "database": "agssa", "entity": "CAnalisis, CSolicitudes", "dbOperation": "write" },
        { "order": 8, "system": "agssasura", "action": "Notifica asesor", "detail": "Email automatico con resultado", "service": "Email" }
      ],
      "results": ["APROBADO", "RECHAZADO", "APLAZADO"]
