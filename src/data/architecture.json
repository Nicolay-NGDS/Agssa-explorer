  "integrations": [
    {
      "id": "wompi",
      "name": "Wompi",
      "description": "Pasarela de pagos para procesar tarjetas de credito/debito",
      "type": "external",
      "category": "payments",
      "usedBy": ["radicacion"],
      "baseUrl": "https://sandbox.wompi.co/v1",
      "authentication": "API Keys (Public + Private)",
      "endpoints": [
        { "method": "POST", "path": "/transactions", "description": "Crear transaccion" },
        { "method": "GET", "path": "/transactions/{id}", "description": "Consultar estado" }
      ],
      "webhook": {
        "path": "/api/wompi/",
        "validation": "SHA256 signature",
        "events": ["APPROVED", "DECLINED", "PENDING", "VOIDED"]
      }
    },
    {
      "id": "truvalidate",
      "name": "TruValidate (TransUnion)",
      "description": "Validacion biometrica de identidad: OTP, documento y reconocimiento facial",
      "type": "external",
      "category": "identity",
      "usedBy": ["radicacion"],
      "baseUrl": "https://www.transuniondecisioncentre.com.mx/TU.DE.PONT_LATAM/",
      "authentication": "OAuth 2.0 (username/password)",
      "endpoints": [
        { "method": "POST", "path": "/token", "description": "Obtener token Bearer" },
        { "method": "POST", "path": "/applications", "description": "Orquestador - determina flujo" },
        { "method": "POST", "path": "/applications/{id}/queues/OTP_PhoneSelection", "description": "Solicitar OTP SMS" },
        { "method": "POST", "path": "/applications/{id}/queues/OTP_PinVerification_OTPInput", "description": "Validar OTP" },
        { "method": "POST", "path": "/applications/{id}/documents", "description": "Crear placeholder documento" },
        { "method": "POST", "path": "/documents/{imgId}", "description": "Subir imagen" },
        { "method": "POST", "path": "/applications/{id}/queues/TSO_ServiceInput", "description": "Validar documento/selfie" }
      ],
      "flows": ["OTP", "Biometria (Documento + Selfie)", "Formulario manual"]
    },
    {
      "id": "zohosign",
      "name": "ZohoSign",
      "description": "Firma electronica de contratos de arrendamiento",
      "type": "external",
      "category": "signature",
      "usedBy": ["agssasura"],
      "baseUrl": "https://sign.zoho.com/api/v1",
      "tokenUrl": "https://accounts.zoho.com/oauth/v2/token",
      "authentication": "OAuth 2.0 (refresh_token)",
      "endpoints": [
        { "method": "POST", "path": "/requests", "description": "Crear solicitud de firma" },
        { "method": "POST", "path": "/requests/{id}/submit", "description": "Enviar para firma" },
        { "method": "GET", "path": "/requests", "description": "Listar solicitudes" },
        { "method": "GET", "path": "/requests/{id}", "description": "Detalle solicitud" },
        { "method": "GET", "path": "/requests/{id}/documents/{docId}/pdf", "description": "Descargar documento" },
        { "method": "GET", "path": "/requests/{id}/completioncertificate", "description": "Certificado de firma" }
      ]
    },
    {
      "id": "aws-s3",
      "name": "AWS S3",
      "description": "Almacenamiento de contratos firmados y documentos",
      "type": "external",
      "category": "storage",
      "usedBy": ["agssasura"],
      "bucket": "agssa-nas",
      "region": "us-east-1",
      "pathPattern": "{year}/{solicitudId}.pdf",
      "operations": ["SubirArchivo", "DownloadFile"]
    },
    {
      "id": "masivapp",
      "name": "MasivApp",
