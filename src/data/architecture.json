      "endpoints": [
        { "method": "POST", "path": "/send-message", "description": "Enviar SMS" }
      ]
    },
    {
      "id": "sura",
      "name": "SURA Cotizador",
      "description": "Consulta de riesgos y validacion en centrales SURA",
      "type": "external",
      "category": "risk",
      "usedBy": ["agssasura"],
      "baseUrl": "https://cotizador.sura.com",
